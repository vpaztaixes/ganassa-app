{
  "name": "ganassa-app",
  "version": "1.0.0",
  "description": "Ganassa - Football Solutions Across Asia",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "node --watch server.js",
    "db:init": "node scripts/initDb.js",
    "db:seed": "node scripts/seed.js",
