<!DOCTYPE html>
<html lang="<%= lang %>">
<head>
    <%- include('../partials/seo-head') %>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="robots" content="noindex, nofollow">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Barlow+Condensed:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="icon" type="image/png" href="/img/Ganassa_Logo_01_Main.png">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
    <link rel="stylesheet" href="/css/main.css">
    <style>
        .error-section {
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            text-align: center;
            background: var(--black);
            color: var(--white);
            padding: 2rem;
        }
        .error-content h1 {
            font-family: var(--heading-font);
            font-size: clamp(5rem, 10vw, 10rem);
            font-weight: 800;
            color: var(--shamrock-green);
            line-height: 1;
            margin-bottom: 1rem;
        }
        .error-content h2 {
            font-family: var(--heading-font);
            font-size: clamp(1.5rem, 3vw, 2.5rem);
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 2px;
            margin-bottom: 1rem;
        }
        .error-content p {
            font-size: 1.2rem;
            color: var(--grey);
            max-width: 500px;
            margin: 0 auto 2rem;
            line-height: 1.6;
        }
        .error-content .btn-primary {
            display: inline-block;
            padding: 15px 40px;
            background: var(--gradient-green);
            color: white;
            font-family: var(--heading-font);
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 2px;
            border-radius: var(--border-radius);
            transition: var(--transition);
        }
        .error-content .btn-primary:hover {
            transform: translateY(-2px);
            box-shadow: var(--box-shadow-hover);
        }
    </style>
</head>
<body>

<%- include('../partials/header') %>

<section class="error-section">
    <div class="error-content">
        <h1>404</h1>
        <h2>Page Not Found</h2>
        <p>The page you're looking for doesn't exist or has been moved.</p>
        <a href="/<%= lang %>/" class="btn-primary">Back to Home</a>
    </div>
</section>

<%- include('../partials/footer') %>

<script src="/js/main.js"></script>
</body>
</html>
