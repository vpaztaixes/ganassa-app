# App
NODE_ENV=production
PORT=3000
BASE_URL=https://your-domain.com

# Production managed Postgres
DATABASE_URL=postgresql://user:password@provider-host:5432/database

# Auth
JWT_SECRET=replace_with_a_long_random_secret
JWT_EXPIRES_IN=24h

# Translation
GOOGLE_TRANSLATE_API_KEY=

# Email (optional)
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=
